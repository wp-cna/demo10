---
layout: layouts/base.njk
title: Events
metaDescription: A selective calendar of events, meetings, and public life around White Plains.
---
{% from "components/macros.njk" import eventCard %}

<section class="image-hero image-hero-events">
  <img src="{{ site.eventHeroImage | withPrefix }}" alt="{{ site.eventHeroImageAlt }}" loading="eager">
  <h1 class="sr-only">Events in White Plains</h1>
</section>

<section class="section-compact">
  <div class="wrap">
    <form class="filter-bar" data-event-filters>
      <label>
        <span>Search</span>
        <input type="search" name="search" placeholder="Event, place, organizer, or tag">
      </label>
      <label>
        <span>Category</span>
        <select name="category">
          <option value="">All categories</option>
          {% for category in eventStore.categories %}
            <option value="{{ category }}">{{ category }}</option>
          {% endfor %}
        </select>
      </label>
      <label>
        <span>Month</span>
        <select name="month">
          <option value="">All months</option>
          {% for monthKey in eventStore.months %}
            <option value="{{ monthKey }}">{{ monthKey | monthYearLabel }}</option>
          {% endfor %}
        </select>
      </label>
      <button class="btn btn-outline" type="reset">Clear</button>
    </form>
  </div>
</section>

<section class="section" data-event-section data-upcoming-events>
  <div class="wrap">
    <div class="section-header">
      <div>
        <h2>Upcoming</h2>
        <p>Events most likely to matter to White Plains residents.</p>
      </div>
      <span class="archive-count" data-event-count>{{ eventStore.upcoming.length }} events</span>
    </div>

    {% if eventStore.upcoming.length %}
      <div class="card-grid">
        {% for event in eventStore.upcoming %}
          {{ eventCard(event) }}
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">
        <h3>Nothing on the calendar right now.</h3>
        <p>Check back soon.</p>
      </div>
    {% endif %}

    <div class="empty-state empty-inline" hidden data-filter-empty>
      <h3>No events match that search.</h3>
      <p>Try a different term or clear the filters.</p>
    </div>

    <div class="empty-state empty-inline" hidden data-upcoming-empty>
      <h3>No upcoming events right now.</h3>
      <p>Check back soon or browse past events.</p>
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="wrap">
    <details class="archive-panel"{% if not eventStore.upcoming.length %} open{% endif %}>
      <summary>
        <span>
          <span class="eyebrow">Archive</span>
          <strong>Past events</strong>
        </span>
        <span class="archive-count">{{ eventStore.past.length }} events</span>
      </summary>
      <div data-event-section>
        <p class="archive-intro">Older listings kept here for reference.</p>
        <div class="card-grid">
          {% for event in eventStore.past %}
            {{ eventCard(event) }}
          {% endfor %}
        </div>
        <div class="empty-state empty-inline" hidden data-filter-empty>
          <h3>No past events match that.</h3>
          <p>Try a broader search or clear filters.</p>
        </div>
      </div>
    </details>
  </div>
</section>
