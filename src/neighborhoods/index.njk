---
layout: layouts/base.njk
title: White Plains Neighborhoods
metaDescription: Explore White Plains through an interactive neighborhood map and a map-aligned neighborhood guide.
---
{% from "components/macros.njk" import neighborhoodCard %}

<section class="image-hero image-hero-neighborhoods">
  <img src="{{ site.neighborhoodsHeroImage | withPrefix }}" alt="{{ site.neighborhoodsHeroImageAlt }}" loading="eager">
  <h1 class="image-hero-label">Neighborhoods</h1>
</section>

<section class="section section-compact neighborhood-map-section" id="neighborhood-map">
  <div class="wrap">
    <div class="interactive-map-layout" data-neighborhood-map>
      <div class="interactive-map-panel">
        <div class="interactive-map-frame">
          <img
            src="{{ representedNeighborhoods.imagePath | withPrefix }}?v={{ representedNeighborhoods.imageVersion }}"
            alt="{{ representedNeighborhoods.imageAlt }}"
            width="{{ representedNeighborhoods.imageWidth }}"
            height="{{ representedNeighborhoods.imageHeight }}"
            loading="eager"
          >
          <svg
            class="interactive-map-svg"
            viewBox="0 0 {{ representedNeighborhoods.viewBoxWidth }} {{ representedNeighborhoods.viewBoxHeight }}"
            aria-label="Interactive map of WPCNA represented White Plains neighborhoods"
            role="img"
            focusable="false"
          >
            {% for neighborhood in representedNeighborhoods.mappedItems %}
              {% if neighborhood.detailUrl %}
                <a
                  href="{{ neighborhood.detailUrl | withPrefix }}"
                  data-map-region="{{ neighborhood.slug }}"
                  aria-label="Open {{ neighborhood.name }} profile"
                >
                  <title>Open {{ neighborhood.name }} profile</title>
                  <path d="{{ neighborhood.mapRegion.pathD }}"></path>
                </a>
              {% else %}
                <g
                  data-map-region="{{ neighborhood.slug }}"
                  role="img"
                  tabindex="0"
                  aria-label="{{ neighborhood.name }} is represented through WPCNA; profile under review"
                >
                  <title>{{ neighborhood.name }} profile under review</title>
                  <path d="{{ neighborhood.mapRegion.pathD }}"></path>
                </g>
              {% endif %}
            {% endfor %}
          </svg>
        </div>
        <p class="interactive-map-caption">Hover or tap one of the highlighted WPCNA-represented neighborhoods to connect the map and the guide cards.</p>
      </div>

      <div class="interactive-map-sidebar">
        <div class="interactive-map-sidebar-intro">
          <p class="neighborhood-map-lead">These neighborhood associations are currently represented through WPCNA.</p>
        </div>

        <div class="map-tile-grid">
          {% for neighborhood in representedNeighborhoods.items %}
            <article class="map-tile" data-map-tile="{{ neighborhood.slug }}"{% if not neighborhood.detailUrl %} tabindex="0" aria-label="{{ neighborhood.name }} profile under review"{% endif %}>
              {% if neighborhood.detailUrl %}
                <a href="{{ neighborhood.detailUrl | withPrefix }}">
              {% else %}
                <div class="map-tile-card" aria-hidden="true">
              {% endif %}
                {% if neighborhood.profilePlaceholder %}
                  <span class="map-tile-media map-tile-placeholder" aria-label="{{ neighborhood.guideImageLabel }}">
                    <span>{{ neighborhood.guideImageLabel }}</span>
                  </span>
                {% elif neighborhood.hero %}
                  <span class="map-tile-media">
                    <img
                      src="{{ (neighborhood.hero.cardImagePath or neighborhood.hero.imagePath) | withPrefix }}"
                      alt="{{ neighborhood.hero.cardAltText or neighborhood.hero.altText }}"
                      loading="lazy"
                    >
                  </span>
                {% endif %}
                <span class="map-tile-body map-tile-body-simple">
                  <strong>{{ neighborhood.name }}</strong>
                </span>
              {% if neighborhood.detailUrl %}
                </a>
              {% else %}
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>

        <div class="neighborhood-guide-cta">
          <a class="link-arrow" href="{{ '/neighborhoods/#neighborhood-areas' | withPrefix }}">Full neighborhood guide</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="neighborhood-areas">
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Neighborhood Areas</p>
        <h2>Neighborhoods grouped by area</h2>
        <p>These neighborhood areas match the updated White Plains map. Fisher Hill is currently populated; other profiles are being normalized.</p>
      </div>
    </div>

    {% for group in neighborhoodStore.guideGroups %}
      <section class="neighborhood-group" id="{{ group.slug }}">
        <div class="neighborhood-group-intro">
          <p class="eyebrow">{{ group.name }}</p>
          <h2>{{ group.name }}</h2>
          <p>{{ group.description }}</p>
        </div>
        <div class="neighborhood-grid">
          {% for neighborhood in group.neighborhoods %}
            {{ neighborhoodCard(neighborhood, true, true) }}
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</section>
